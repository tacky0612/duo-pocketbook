# terraform.tfvars にコピーして値を設定する（terraform.tfvars はコミットしない）

# 表示名（account*_name）は設定しない。アプリ側の既定値（太郎/花子）を使い、変更は画面から行う。
# login_id は初期ログインID（AccountIDとは別。ログイン後に画面から変更可能）
account1_login_id = "taro"
# go run ./cmd/hashpw '<password>' で生成
account1_password_hash = "$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

account2_login_id      = "hanako"
account2_password_hash = "$2a$10$yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# openssl rand -base64 48 などで生成
jwt_secret = "long-random-secret"

# GitHub Pages のURL（例）。CORS を実オリジンに限定する（"*" にしない）
allowed_origins = ["https://<username>.github.io"]

# Lambda 予約同時実行数の上限（低く固定してコスト暴走を防ぐ）。2人利用なら2で十分
# -1 で未設定。正の値は同時実行上限(既定10の新規アカウント)を引き上げてから
reserved_concurrency = -1

# 正規クライアント識別用の事前共有キー。フロントの VITE_CLIENT_KEY と同じ値にする。
# 例: openssl rand -hex 24 で生成。空なら無効。
client_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# コスト監視の通知先メール（任意）。設定すると月$1超過でBudgetsが通知。空なら作成しない
budget_alert_email = ""

# --- Cloudflare（案1: Access で実行元を制限）。使う場合のみ設定 ---
# 認証は環境変数 CLOUDFLARE_API_TOKEN で渡す（tfvars には書かない）
enable_cloudflare     = false
cloudflare_account_id = "" # Cloudflare ダッシュボード右サイドで確認
cloudflare_zone_id    = "" # ゾーン
app_domain            = "example.test" # アプリを載せるサブドメイン
client_emails         = ["you@example.com", "partner@example.com"]
pages_project_name    = "duo-pocketbook"
github_owner          = "tacky0612"
github_repo           = "duo-pocketbook"
# client_key は上で設定した値を Worker の秘密ヘッダにも再利用する
